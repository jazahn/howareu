{
  "expo": {
    "name": "howareu",
    "slug": "howareu",
    "scheme": "howareu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jazahn.howareyou",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.811550455435-sbaghribhch5aosekrlhbn5pjv1a3480"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.811550455435-sbaghribhch5aosekrlhbn5pjv1a3480"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "howareu"
    },
    "extra": {
      "eas": {
        "projectId": "7dea7d4c-a3aa-49c9-9b22-73de9d20eb79"
      }
    },
    "owner": "jazahn",
    "plugins": [
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPodfileProperties": {
              "SWIFT_VERSION": "5.0"
            }
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
